# =============================================================================
# ESP32-S3 Firmware Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Variables can also be set via environment or FIRMWARE_DOTENV_PATH.

# =============================================================================
# Common Settings (required for all features)
# =============================================================================

# WiFi credentials (required)
SSID=your_wifi_ssid
PASSWORD=your_wifi_password

# Log level: error | warn | info | debug | trace (optional, default: info)
LOG_LEVEL=info

# Device identity (optional)
# DEVICE_ID=pump-sensor-01
# DEVICE_VERSION=1.0.0

# =============================================================================
# Streaming Feature (--features streaming)
# =============================================================================
# Streams raw audio to a TCP server for dataset collection.

# TCP server endpoint (required for streaming)
SERVER_IP=192.168.1.100
SERVER_PORT=3000

# Recording mode: Continuous | PumpGated (optional, default: PumpGated)
# - Continuous: always stream audio
# - PumpGated: stream only when pump is detected via ADC
MODE=PumpGated

# =============================================================================
# Inference Feature (--features inference)
# =============================================================================
# Runs on-device NN inference and reports pump state.
# Choose either TCP or MQTT output (use --features inference,mqtt for MQTT).

# --- TCP Output (default) ---
# Reuses SERVER_IP and SERVER_PORT from above

# --- MQTT Output (--features inference,mqtt) ---
# MQTT_BROKER_IP=192.168.1.100
# MQTT_BROKER_PORT=1883
# MQTT_TOPIC=home/pump/state
# MQTT_CLIENT_ID=pump-sensor-01
# MQTT_USERNAME=iot_user
# MQTT_PASSWORD=iot_password
